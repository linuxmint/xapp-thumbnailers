#!/usr/bin/python3

import os
import subprocess
import sys
import tempfile
from elftools.elf.elffile import ELFFile

import gi
gi.require_version("XApp", "1.0")
from gi.repository import XApp

import XappThumbnailers
t = XappThumbnailers.Thumbnailer()

# Find the section header offset within the ELF file
with open(t.args.input, 'rb') as f:
    elf = ELFFile(f)
    app_image_offset = elf['e_shoff'] + (elf['e_shentsize'] * elf['e_shnum'])
    f.seek(app_image_offset)
    payload_magic = f.read(6)

def lookup_icon(filename):
    if payload_magic == b'DWARFS':
        with tempfile.TemporaryDirectory(dir=XApp.get_tmp_dir()) as tmpdir:
            extract_icon(tmpdir, filename)
            path = os.path.join(tmpdir, filename)

            if not os.path.exists(path) and not os.path.islink(path):
                return ''

            if os.path.islink(path):
                return '%s -> %s' % (filename, os.readlink(path))

            return filename

    return subprocess.check_output([
            'unsquashfs',
            '-o', str(app_image_offset),
            '-ll',
            t.args.input,
            filename
        ]).decode()

def extract_icon(outdir, filename):
    if payload_magic == b'DWARFS':
        os.mkdir(outdir)
        cmd = [
            'dwarfsextract',
            '-i', t.args.input,
            '-O', str(app_image_offset),
            '-o', outdir,
            '--pattern', filename,
            '--skip-devices',
            '--skip-specials',
            '--log-level', 'error',
        ]
    else:
        cmd = [
            'unsquashfs',
            '-o', str(app_image_offset),
            '-d', outdir,
            t.args.input,
            filename,
        ]

    subprocess.run(cmd, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

# Find the location of the icon inside the AppImage payload
icon_path = '.DirIcon'
while True:
    output = lookup_icon(icon_path)

    if not output:
        # File not found, fail
        sys.exit(1)

    if ' -> ' not in output:
        # icon path is not a symlink, let's use it
        break

    icon_path = output.strip().split(' -> ')[1]
    # Some appimages use local apppimage paths, e.g., ./usr/applications/...
    if icon_path[0:2] == './':
        icon_path = icon_path[2:]

# Extract the icon
with tempfile.TemporaryDirectory(dir=XApp.get_tmp_dir()) as tmpdir:
    outdir = os.path.join(tmpdir, 'out')
    extract_icon(outdir, icon_path)
    icon_path = os.path.join(outdir, icon_path)
    success = t.save_path(icon_path)
sys.exit(0 if success else 1)
